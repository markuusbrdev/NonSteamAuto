{
  "name": "non-steam-automation",
  "private": true,
  "version": "0.0.0",
  "description": "Automation tool for managing non-steam games",
  "author": {
    "name": "Marcus",
    "email": "marcus@example.com"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "pack": "vite build && electron-builder --dir",
    "build": "tsc && vite build && electron-builder --linux",
    "build:linux": "vite build && electron-builder --linux",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview"
  },
  "dependencies": {
    "axios": "^1.18.1",
    "chokidar": "^5.0.0",
    "crc-32": "^1.2.2",
    "electron-store": "^11.0.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "steam-binary-vdf": "^0.1.0",
    "tar": "^7.5.20",
    "vdf-parser": "^1.2.1"
  },
  "devDependencies": {
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.5.0",
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.2.2",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "main": "dist-electron/main.js",
  "build": {
    "appId": "com.marcus.nonsteamauto",
    "productName": "NonSteamAutomation",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "linux": {
      "target": [
        "AppImage",
        "tar.gz"
      ],
      "category": "Utility",
      "icon": "build/icon.png"
    },
    "rpm": {
      "synopsis": "Non-Steam Automation Tool",
      "description": "Automation tool for managing non-steam games",
      "fpm": [
        "--rpm-rpmbuild-define", "_build_id_links none",
        "--rpm-rpmbuild-define", "__spec_install_pre %{nil}",
        "--rpm-rpmbuild-define", "__os_install_post %{nil}",
        "--rpm-rpmbuild-define", "debug_package %{nil}"
      ]
    }
  }
}
